<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.3.xsd">

    <changeSet id="1" author="RajKumar">
        <createTable tableName="users">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="first_name" type="VARCHAR(255)"/>
            <column name="last_name" type="VARCHAR(255)"/>
            <column name="email" type="VARCHAR(255)">
                <constraints unique="true" nullable="false"/>
            </column>
            <column name="password" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="role" type="VARCHAR(50)"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>
    </changeSet>

    <changeSet id="2" author="RajKumar">
        <createTable tableName="hotels">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="location" type="VARCHAR(255)"/>
            <column name="description" type="TEXT"/>
            <column name="amenities" type="TEXT"/> 
            <column name="image_url" type="VARCHAR(512)"/>
            <column name="rating" type="DOUBLE"/> 
            <column name="is_active" type="BOOLEAN" defaultValueBoolean="true"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>
    </changeSet>

    <changeSet id="3" author="RajKumar">
        <createTable tableName="rooms">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="hotel_id" type="BIGINT">
                <constraints foreignKeyName="fk_room_hotel" referencedTableName="hotels" referencedColumnNames="id"/>
            </column>
            <column name="room_type" type="VARCHAR(50)"/>
            <column name="description" type="TEXT"/>
            <column name="floor_number" type="INT"/> <column name="price_per_night" type="DECIMAL(19,2)"/>
            <column name="capacity" type="INT"/>
            <column name="available" type="BOOLEAN" defaultValueBoolean="true"/>
            <column name="image_url" type="VARCHAR(512)"/>
        </createTable>
    </changeSet>

    <changeSet id="4" author="RajKumar">
        <createTable tableName="bookings">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="user_id" type="UUID">
                <constraints foreignKeyName="fk_booking_user" referencedTableName="users" referencedColumnNames="id"/>
            </column>
            <column name="room_id" type="BIGINT">
                <constraints foreignKeyName="fk_booking_room" referencedTableName="rooms" referencedColumnNames="id"/>
            </column>
            <column name="check_in_date" type="DATE"/>
            <column name="check_out_date" type="DATE"/>
            <column name="total_amount" type="DECIMAL(19,2)"/>
            <column name="status" type="VARCHAR(50)"/>
            <column name="confirmation_number" type="VARCHAR(100)"/>
            <column name="booked_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>
    </changeSet>

    <changeSet id="5" author="RajKumar">
        <createTable tableName="payments">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="booking_id" type="UUID">
                <constraints unique="true" foreignKeyName="fk_payment_booking" referencedTableName="bookings" referencedColumnNames="id"/>
            </column>
            <column name="amount" type="DECIMAL(19,2)">
                <constraints nullable="false"/>
            </column>
            <column name="method" type="VARCHAR(50)"/>
            <column name="status" type="VARCHAR(50)"/>
            <column name="transaction_id" type="VARCHAR(100)">
                <constraints unique="true"/>
            </column>
            <column name="payment_date" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>
    </changeSet>

</databaseChangeLog>